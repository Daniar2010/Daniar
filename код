import tkinter as tk
from tkinter import ttk, messagebox
import random
import json
import os
from datetime import datetime

# Предопределённые цитаты
DEFAULT_QUOTES = [
    {"text": "Будь изменением, которое ты хочешь видеть в мире.", "author": "Махатма Ганди", "theme": "Мотивация"},
    {"text": "Жизнь — это то, что с тобой происходит, пока ты строишь планы.", "author": "Джон Леннон", "theme": "Жизнь"},
    {"text": "Воображение важнее знания.", "author": "Альберт Эйнштейн", "theme": "Наука"},
    {"text": "Стань хозяином своей судьбы.", "author": "Вергилий", "theme": "Мотивация"},
    {"text": "Только тот, кто рискует идти далеко, узнает, как далеко можно зайти.", "author": "Т.С. Элиот", "theme": "Риск"},
]

HISTORY_FILE = "quotes_history.json"

class QuoteGenerator:
    def __init__(self, root):
        self.root = root
        self.root.title("Random Quote Generator")
        self.root.geometry("650x550")
        
        # Загрузка истории
        self.history = self.load_history()
        
        # Список доступных цитат (можно расширять)
        self.quotes = DEFAULT_QUOTES.copy()
        
        # Создание GUI
        self.create_widgets()
        
        # Обновление отображения
        self.update_quote_display()
        self.update_history_list()
        self.update_filter_options()
    
    def create_widgets(self):
        # Рамка для текущей цитаты
        frame_quote = tk.LabelFrame(self.root, text="📜 Случайная цитата", padx=10, pady=10)
        frame_quote.pack(fill="both", expand=True, padx=10, pady=5)
        
        self.lbl_quote_text = tk.Label(frame_quote, text="", wraplength=550, font=("Arial", 12, "italic"), justify="center")
        self.lbl_quote_text.pack(pady=10)
        
        self.lbl_quote_author = tk.Label(frame_quote, text="", font=("Arial", 10), fg="gray")
        self.lbl_quote_author.pack()
        
        self.lbl_quote_theme = tk.Label(frame_quote, text="", font=("Arial", 9), fg="blue")
        self.lbl_quote_theme.pack()
        
        btn_generate = tk.Button(frame_quote, text="✨ Сгенерировать цитату", command=self.generate_random_quote, bg="#4CAF50", fg="white", font=("Arial", 10, "bold"))
        btn_generate.pack(pady=10)
        
        # Рамка для фильтрации
        frame_filter = tk.LabelFrame(self.root, text="🔍 Фильтр", padx=10, pady=10)
        frame_filter.pack(fill="x", padx=10, pady=5)
        
        tk.Label(frame_filter, text="Автор:").grid(row=0, column=0, sticky="w")
        self.author_filter = ttk.Combobox(frame_filter, values=["Все"], state="readonly")
        self.author_filter.grid(row=0, column=1, padx=5, pady=5)
        self.author_filter.bind("<<ComboboxSelected>>", lambda e: self.update_history_list())
        
        tk.Label(frame_filter, text="Тема:").grid(row=0, column=2, sticky="w", padx=(10,0))
        self.theme_filter = ttk.Combobox(frame_filter, values=["Все"], state="readonly")
        self.theme_filter.grid(row=0, column=3, padx=5, pady=5)
        self.theme_filter.bind("<<ComboboxSelected>>", lambda e: self.update_history_list())
        
        btn_clear_filters = tk.Button(frame_filter, text="Сбросить фильтр", command=self.clear_filters)
        btn_clear_filters.grid(row=0, column=4, padx=10)
        
        # Рамка для истории
        frame_history = tk.LabelFrame(self.root, text="📚 История цитат", padx=10, pady=10)
        frame_history.pack(fill="both", expand=True, padx=10, pady=5)
        
        self.history_listbox = tk.Listbox(frame_history, height=10)
        self.history_listbox.pack(side="left", fill="both", expand=True)
        
        scrollbar = tk.Scrollbar(frame_history, orient="vertical", command=self.history_listbox.yview)
        scrollbar.pack(side="right", fill="y")
        self.history_listbox.config(yscrollcommand=scrollbar.set)
        
        # Кнопки управления
        frame_buttons = tk.Frame(self.root)
        frame_buttons.pack(fill="x", padx=10, pady=5)
        
        btn_add = tk.Button(frame_buttons, text="➕ Добавить новую цитату", command=self.add_quote_dialog, bg="#2196F3", fg="white")
        btn_add.pack(side="left", padx=5)
        
        btn_clear_history = tk.Button(frame_buttons, text="🗑️ Очистить историю", command=self.clear_history, bg="#f44336", fg="white")
        btn_clear_history.pack(side="right", padx=5)
    
    def generate_random_quote(self):
        """Выбирает случайную цитату и добавляет в историю"""
        if not self.quotes:
            messagebox.showwarning("Нет цитат", "Добавьте хотя бы одну цитату вручную.")
            return
        
        quote = random.choice(self.quotes)
        self.current_quote = quote
        
        # Добавляем в историю с датой
        history_entry = {
            "text": quote["text"],
            "author": quote["author"],
            "theme": quote["theme"],
            "timestamp": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        }
        self.history.append(history_entry)
        self.save_history()
        
        self.update_quote_display()
        self.update_history_list()
    
    def update_quote_display(self):
        """Отображает текущую цитату"""
        if hasattr(self, 'current_quote'):
            self.lbl_quote_text.config(text=f"«{self.current_quote['text']}»")
            self.lbl_quote_author.config(text=f"— {self.current_quote['author']}")
            self.lbl_quote_theme.config(text=f"Тема: {self.current_quote['theme']}")
        else:
            self.lbl_quote_text.config(text="Нажмите «Сгенерировать цитату»")
            self.lbl_quote_author.config(text="")
            self.lbl_quote_theme.config(text="")
    
    def update_history_list(self):
        """Обновляет список истории с учётом фильтров"""
        self.history_listbox.delete(0, tk.END)
        
        author = self.author_filter.get()
        theme = self.theme_filter.get()
        
        for entry in self.history:
            if author != "Все" and entry["author"] != author:
                continue
            if theme != "Все" and entry["theme"] != theme:
                continue
            
            display_text = f"[{entry['timestamp']}] {entry['author']}: {entry['text'][:60]}..."
            self.history_listbox.insert(tk.END, display_text)
    
    def update_filter_options(self):
        """Обновляет выпадающие списки для фильтров на основе истории"""
        authors = sorted(set([q["author"] for q in self.quotes] + [h["author"] for h in self.history]))
        themes = sorted(set([q["theme"] for q in self.quotes] + [h["theme"] for h in self.history]))
        
        self.author_filter['values'] = ["Все"] + authors
        self.theme_filter['values'] = ["Все"] + themes
        
        if not self.author_filter.get():
            self.author_filter.set("Все")
        if not self.theme_filter.get():
            self.theme_filter.set("Все")
    
    def clear_filters(self):
        """Сбрасывает фильтры"""
        self.author_filter.set("Все")
        self.theme_filter.set("Все")
        self.update_history_list()
    
    def add_quote_dialog(self):
        """Диалог добавления новой цитаты с проверкой"""
        dialog = tk.Toplevel(self.root)
        dialog.title("Добавить цитату")
        dialog.geometry("400x250")
        
        tk.Label(dialog, text="Текст цитаты:").pack(pady=(10,0))
        text_entry = tk.Text(dialog, height=5, width=50)
        text_entry.pack(pady=5)
        
        tk.Label(dialog, text="Автор:").pack()
        author_entry = tk.Entry(dialog, width=50)
        author_entry.pack(pady=5)
        
        tk.Label(dialog, text="Тема:").pack()
        theme_entry = tk.Entry(dialog, width=50)
        theme_entry.pack(pady=5)
        
        def save_quote():
            text = text_entry.get("1.0", tk.END).strip()
            author = author_entry.get().strip()
            theme = theme_entry.get().strip()
            
            # Проверка на пустые строки
            if not text or not author or not theme:
                messagebox.showerror("Ошибка", "Все поля обязательны для заполнения!")
                return
            
            new_quote = {"text": text, "author": author, "theme": theme}
            self.quotes.append(new_quote)
            self.update_filter_options()
            messagebox.showinfo("Успех", "Цитата добавлена в общий список!")
            dialog.destroy()
        
        tk.Button(dialog, text="Сохранить", command=save_quote, bg="#4CAF50", fg="white").pack(pady=10)
    
    def clear_history(self):
        """Очищает всю историю"""
        if messagebox.askyesno("Подтверждение", "Вы уверены, что хотите очистить всю историю?"):
            self.history = []
            self.save_history()
            self.update_history_list()
    
    def load_history(self):
        """Загружает историю из JSON файла"""
        if os.path.exists(HISTORY_FILE):
            with open(HISTORY_FILE, "r", encoding="utf-8") as f:
                return json.load(f)
        return []
    
    def save_history(self):
        """Сохраняет историю в JSON файл"""
        with open(HISTORY_FILE, "w", encoding="utf-8") as f:
            json.dump(self.history, f, ensure_ascii=False, indent=4)

if __name__ == "__main__":
    root = tk.Tk()
    app = QuoteGenerator(root)
    root.mainloop()
